{
  "openapi": "3.0.0",
  "info": {
    "title": "API Base E-commerce",
    "description": "Documentação da API com Swagger para editar e expandir conforme o projeto.",
    "contact": {
      "name": "Hicaro André"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/users": {
      "post": {
        "summary": "Cria um novo usuário",
        "tags": ["Usuários"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cpf", "name", "email", "password"],
                "properties": {
                  "cpf": { "type": "string" },
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário criado com sucesso" },
          "400": { "description": "Erro de validação" }
        }
      },
      "get": {
        "summary": "Lista todos os usuários",
        "tags": ["Usuários"],
        "responses": {
          "200": {
            "description": "Lista de usuários",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "_id": { "type": "string" },
                      "cpf": { "type": "string" },
                      "name": { "type": "string" },
                      "email": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "summary": "Busca um usuário por ID",
        "tags": ["Usuários"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuário encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": { "type": "string" },
                    "cpf": { "type": "string" },
                    "name": { "type": "string" },
                    "email": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": { "description": "Usuário não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um usuário por ID",
        "tags": ["Usuários"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cpf": { "type": "string" },
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Usuário atualizado com sucesso" },
          "404": { "description": "Usuário não encontrado" }
        }
      },
      "delete": {
        "summary": "Remove um usuário por ID",
        "tags": ["Usuários"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Usuário deletado com sucesso" },
          "404": { "description": "Usuário não encontrado" }
        }
      }
    },
    "/products": {
      "post": {
        "summary": "Cria um novo produto",
        "tags": ["Produtos"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["productName", "price", "stock"],
                "properties": {
                  "productName": { "type": "string" },
                  "price": { "type": "number" },
                  "stock": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Produto criado com sucesso" },
          "400": { "description": "Erro de validação" }
        }
      },
      "get": {
        "summary": "Lista todos os produtos",
        "tags": ["Produtos"],
        "responses": {
          "200": {
            "description": "List de produtos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "_id": { "type": "string" },
                      "productName": { "type": "string" },
                      "price": { "type": "number" },
                      "stock": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Busca um produto por ID",
        "tags": ["Produtos"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Produto encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": { "type": "string" },
                    "productName": { "type": "string" },
                    "price": { "type": "number" },
                    "stock": { "type": "integer" }
                  }
                }
              }
            }
          },
          "404": { "description": "Produto não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um produto por ID",
        "tags": ["Produtos"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "productName": { "type": "string" },
                  "price": { "type": "number" },
                  "stock": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Produto atualizado com sucesso" },
          "404": { "description": "Produto não encontrado" }
        }
      },
      "delete": {
        "summary": "Remove um produto por ID",
        "tags": ["Produtos"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Produto deletado com sucesso" },
          "404": { "description": "Produto não encontrado" }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
